    "bs58": "^6.0.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "comlink": "^4.4.2",
    "diff": "^9.0.0",
    "hash-wasm": "^4.12.0",
    "he": "^1.2.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.469.0",
    "papaparse": "^5.5.3",
    "prettier": "^3.8.4",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "regexp-tree": "^0.1.27",
